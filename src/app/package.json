{
  "name": "my-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "clean:dev": "cross-env APP_VARIANT=development npx expo prebuild --platform android --clean",
    "clean:prev": "cross-env APP_VARIANT=preview npx expo prebuild --platform android --clean",
    "build:dev": "npm run clean:dev && cross-env APP_VARIANT=development npx expo run:android",
    "build:prev": "npm run clean:prev && cross-env APP_VARIANT=preview npx expo run:android --variant release",
    "build:both": "npm run build:dev && npm run build:prev",
    "update:prev": "cross-env APP_VARIANT=preview npx eas update --branch preview --message",
    "update:prod": "cross-env APP_VARIANT=production npx eas update --branch production --message",
    "docs": "typedoc --entryPointStrategy expand ./src --exclude **/*.test.ts --out docs --skipErrorChecking",
    "storybook-generate": "sb-rn-get-stories",
    "clean:prod": "cross-env APP_VARIANT=production npx expo prebuild --platform android --clean",
    "build:aab": "cd android && gradlew bundleRelease"
  },
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@expo/config-plugins": "^55.0.7",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-community/slider": "^5.1.2",
    "@react-navigation/core": "^7.14.0",
    "@react-navigation/native": "^7.1.28",
    "@sfourdrinier/react-native-ble-plx": "^3.7.10",
    "@storybook/react": "^10.3.3",
    "@storybook/react-native": "^10.3.0",
    "@supabase/supabase-js": "^2.95.3",
    "babel-loader": "^8.4.1",
    "babel-preset-expo": "~54.0.10",
    "buffer": "^6.0.3",
    "dotenv": "^17.3.1",
    "expo": "~54.0.32",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-navigation-bar": "~5.0.10",
    "expo-notifications": "~0.32.16",
    "expo-sharing": "^14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.16",
    "i18next": "^25.8.13",
    "nativewind": "^4.0.36",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-css": "^3.0.1",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-uuid": "^2.0.3",
    "react-native-web": "^0.21.0",
    "storybook": "^10.3.3",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@storybook/addon-ondevice-actions": "^10.3.0",
    "@storybook/addon-ondevice-backgrounds": "^10.3.0",
    "@storybook/addon-ondevice-controls": "^10.3.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "~19.1.0",
    "cross-env": "^10.1.0",
    "eas-cli": "^18.4.0",
    "postcss": "^8.5.6",
    "react-native-svg-transformer": "^1.5.3",
    "tailwindcss": "^3.3.2",
    "typedoc": "^0.28.18",
    "typescript": "~5.9.2"
  },
  "private": true
}
